local function fVal(m)
    local base = 0
    local seed = m:GetAttribute("CorePartName") or m:GetAttribute("SeedName")
    if seed and FCalc then pcall(function() base = FCalc(seed, 1, nil, LP, nil) end) end
    local mul = m:GetAttribute("SizeMulti") or m:GetAttribute("SizeMultiplier") or 1
    local bonus = m:GetAttribute("Mutation") and 2.35 or 1
    return base * (tonumber(mul)^2.65) * bonus
end
local function ripe(m)
    local age, mx = tonumber(m:GetAttribute("Age")), tonumber(m:GetAttribute("MaxAge"))
    if age and mx then return age >= mx - 0.001 end
    for _, d in ipairs(m:GetDescendants()) do if d:IsA("ProximityPrompt") and CollectionService:HasTag(d, "HarvestPrompt") then return true end end
    return false
end

local function ownTargets(filt)
    local useCrop = filt and next(S.hCrops) ~= nil
    local out = {}
    local plot = myPlot(); if not plot then return out end
    local plants = plot:FindFirstChild("Plants"); if not plants then return out end
    local function consider(m)
        if not m:GetAttribute("PlantId") then return end
        local crop = m:GetAttribute("CorePartName") or m:GetAttribute("SeedName")
        local mutOk = (not filt) or (not S.hMuts) or (m:GetAttribute("Mutation") ~= nil)
        if ((not useCrop) or (crop and S.hCrops[crop] == true)) and mutOk then out[#out + 1] = m end
    end
    for _, plant in ipairs(plants:GetChildren()) do
        local fr = plant:FindFirstChild("Fruits")
        local fruits = fr and fr:GetChildren() or {}
        if #fruits > 0 then for _, m in ipairs(fruits) do if ripe(m) then consider(m) end end
        elseif ripe(plant) then consider(plant) end
    end
    return out
end

local function stealTgts()
    local out = {}
