local evLbl = TTm:Paragraph({ Title = "活动", Desc = "-" })
local evTLbl = TTm:Paragraph({ Title = "剩余", Desc = "-" })
local sLbl = TTm:Paragraph({ Title = "种子商店", Desc = "-" })
local gLbl = TTm:Paragraph({ Title = "装备商店", Desc = "-" })
local cLbl = TTm:Paragraph({ Title = "箱子商店", Desc = "-" })
lp(1, function()
    local raw, _, endsAt = Workspace:GetAttribute("ActiveWeather"), Workspace:GetAttribute("ActivePhase"), tonumber(Workspace:GetAttribute("PhaseDuration"))
    evLbl:SetDesc(raw)
    evTLbl:SetDesc(endsAt and math.max(0, endsAt - os.time()) or "-")
    local s = restockIn("SeedShop") sLbl:SetDesc(s and math.max(0, s) or "-")
    local g = restockIn("GearShop") gLbl:SetDesc(g and math.max(0, g) or "-")
    local c = restockIn("CrateShop") cLbl:SetDesc(c and math.max(0, c) or "-")
end)

