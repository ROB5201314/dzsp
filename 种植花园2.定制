local perfEnabled = false
local perfConns = {}
local playerChars = {}
local function refreshPlayerList()
    table.clear(playerChars)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then playerChars[plr.Character] = true end
    end
end
local function isPlayerPart(part)
    for char in pairs(playerChars) do if part:IsDescendantOf(char) then return true end end
    return false
end
local function isGreenOrBrown(part)
    local color = part.Color
    local r, g, b = color.R, color.G, color.B
    if g > 0.35 and g > r * 1.5 and g > b * 1.5 then return true end
    if r >= 0.3 and r <= 0.8 and g >= 0.15 and g <= 0.5 and b <= 0.3 then
        if math.abs(r - g) < 0.4 then return true end
    end
    return false
end
local function processInstance(obj)
    if obj:IsA("BasePart") then
        if isPlayerPart(obj) then return end
        if not isGreenOrBrown(obj) then
            obj.Transparency = 1
            obj.CanCollide = false
        end
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        if not isPlayerPart(obj) then obj:Destroy() end
    elseif obj:IsA("Light") or obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
        obj.Enabled = false
    elseif obj:IsA("ParticleEmitter") then obj.Enabled = false
    elseif obj:IsA("Beam") then obj.Enabled = false
    elseif obj:IsA("Trail") then obj.Enabled = false
    elseif obj:IsA("Highlight") then obj.Enabled = false
    elseif obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or obj:IsA("SunRaysEffect") or obj:IsA("ColorCorrectionEffect") then
        obj.Enabled = false
    end
end

