_G.ESP_Enabled = false
local espCache = {}
local espBoxOutlineColor = Color3.new(0,0,0)
local espBoxColor = Color3.new(1,0,0)
local espNameEnemyColor = Color3.new(1,0,0)
local espNameTeamColor = Color3.new(0,1,0)
local espHealthOutlineColor = Color3.new(0,0,0)
local espHealthHighColor = Color3.new(0,1,0)
local espHealthLowColor = Color3.new(1,0,0)
local CHAR_SIZE = Vector2.new(4,6)

local function floor2(v) return Vector2.new(math.floor(v.X), math.floor(v.Y)) end

local function createEsp(player)
    if player == LocalPlayer or espCache[player] then return end
    if espCache[player] then
        for _, d in pairs(espCache[player]) do d:Remove() end
        espCache[player] = nil
    end
    local esp = {}
    esp.boxOutline = Drawing.new("Square")
    esp.boxOutline.Color = espBoxOutlineColor
    esp.boxOutline.Thickness = 3
    esp.boxOutline.Filled = false
    esp.boxOutline.Visible = false
    esp.box = Drawing.new("Square")
    esp.box.Color = espBoxColor
    esp.box.Thickness = 1
    esp.box.Filled = false
    esp.box.Visible = false
    esp.name = Drawing.new("Text")
    esp.name.Font = (syn and not RectDynamic) and 2 or 1
    esp.name.Outline = true
    esp.name.Center = true
    esp.name.Size = 13
    esp.name.Visible = false
    esp.healthOutline = Drawing.new("Line")
    esp.healthOutline.Thickness = 3
    esp.healthOutline.Color = espHealthOutlineColor
    esp.healthOutline.Visible = false
    esp.health = Drawing.new("Line")
    esp.health.Thickness = 1
    esp.health.Visible = false
    espCache[player] = esp
end

local function removeEsp(player)
    local esp = espCache[player]
    if esp then
        for _, d in pairs(esp) do d:Remove() end
        espCache[player] = nil
    end
end

local function updateEsp()
    if not Camera then Camera = Workspace.CurrentCamera end
    if not _G.ESP_Enabled then
        for _, esp in pairs(espCache) do
            for _, d in pairs(esp) do d.Visible = false end
        end
        return
    end
    for player, esp in pairs(espCache) do
        if not player or not player.Parent then
            removeEsp(player)
            continue
        end
        local char = player.Character
        if not char then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end
        local isEnemy = (not player.Team) or (player.Team ~= LocalPlayer.Team)
        local cf = char:GetPivot()
        local scr, onScr = Camera:WorldToViewportPoint(cf.Position)
        if onScr then
            local fH = math.tan(math.rad(Camera.FieldOfView*0.5)) * 2 * scr.Z
            local size = Camera.ViewportSize.Y / fH * CHAR_SIZE
            local pos = Vector2.new(scr.X, scr.Y)
            esp.boxOutline.Size = floor2(size)
            esp.boxOutline.Position = floor2(pos - size*0.5)
            esp.box.Size = esp.boxOutline.Size
            esp.box.Position = esp.boxOutline.Position
            esp.name.Text = string.lower(player.Name)
            esp.name.Position = floor2(pos - Vector2.yAxis*(size.Y*0.5 + esp.name.TextBounds.Y + 2))
            esp.name.Color = isEnemy and espNameEnemyColor or espNameTeamColor
            local hum = char:FindFirstChildOfClass("Humanoid")
            local hp = (hum and hum.Health or 100)/100
            esp.healthOutline.From = floor2(pos - size*0.5) - Vector2.xAxis*5
            esp.healthOutline.To = floor2(pos - size*Vector2.new(0.5,-0.5)) - Vector2.xAxis*5
            esp.health.From = esp.healthOutline.To
            esp.health.To = floor2(esp.healthOutline.To:Lerp(esp.healthOutline.From, hp))
            esp.health.Color = espHealthLowColor:Lerp(espHealthHighColor, hp)
            esp.healthOutline.From -= Vector2.yAxis
            esp.healthOutline.To += Vector2.yAxis
            for _, d in pairs(esp) do d.Visible = true end
        else
            for _, d in pairs(esp) do d.Visible = false end
        end
    end
end

