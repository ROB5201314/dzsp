_G.Aimbot_Enabled = false
_G.FOV_Visible = false
_G.LockNPC = false
_G.StrongLock = false
_G.NearestCrosshair = true

local aimFOV = 50
local aimSmooth = 1
local aimPredict = 0
local aimPart = "Head"
local friendCheck = true
local visibleCheck = false
local silentAim = false
local lockTarget = false
local selectedTarget = nil

local partPriority = {"Head", "HumanoidRootPart", "UpperTorso", "Torso"}

local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Thickness = 2
fovCircle.Color = Color3.fromRGB(0,255,0)
fovCircle.Filled = false
fovCircle.Radius = aimFOV

local function updateFOVPos()
    local cam = Workspace.CurrentCamera
    if cam then
        local vp = cam.ViewportSize
        fovCircle.Position = Vector2.new(vp.X/2, vp.Y/2)
    end
end
updateFOVPos()

local strongLockTarget = nil

local function getPart(character)
    for _, partName in ipairs(partPriority) do
        local part = character:FindFirstChild(partName)
        if part then return part end
    end
    return character:FindFirstChildWhichIsA("BasePart")
end

local function isVisible(part)
    if not visibleCheck then return true end
    local cam = Workspace.CurrentCamera
    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {LocalPlayer.Character}
    ray.FilterType = Enum.RaycastFilterType.Blacklist
    ray.IgnoreWater = true
    local result = Workspace:Raycast(cam.CFrame.Position, (part.Position - cam.CFrame.Position).Unit * 1000, ray)
    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end
    return false
end

local function getAvailableTargets()
    local targets = {}
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char then
                local part = getPart(char)
                local hum = char:FindFirstChildOfClass("Humanoid")
                if part and hum and hum.Health > 0 then
                    table.insert(targets, {type = "Player", instance = plr, part = part, hum = hum, char = char})
                end
            end
        end
    end
    if _G.LockNPC then
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local part = getPart(obj)
                    if part then
                        table.insert(targets, {type = "NPC", instance = obj, part = part, hum = hum, char = obj})
                    end
                end
            end
        end
    end
    return targets
end

local function getTarget()
    if lockTarget and selectedTarget then
        local plr = Players:FindFirstChild(selectedTarget)
        if plr and plr.Character then
            local part = getPart(plr.Character)
            if part and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character.Humanoid.Health > 0 then
                return plr, part
            end
        end
        return nil
    end

    if _G.StrongLock and strongLockTarget then
        local target = strongLockTarget
        if target.part and target.part.Parent and target.hum and target.hum.Health > 0 then
            if isVisible(target.part) then
                return target.instance, target.part
            else
                strongLockTarget = nil
            end
        else
            strongLockTarget = nil
        end
    end

    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local best, bestDist, bestTargetObj = nil, math.huge, nil

    local targets = getAvailableTargets()
    for _, t in ipairs(targets) do
        if friendCheck and t.type == "Player" and t.instance:IsFriendsWith(LocalPlayer.UserId) then
            continue
        end
        if not isVisible(t.part) then continue end
        local pos, onScreen = Camera:WorldToViewportPoint(t.part.Position)
        if not onScreen then continue end
        local screenPos = Vector2.new(pos.X, pos.Y)
        local distFromCrosshair = (screenPos - center).Magnitude
        if distFromCrosshair <= aimFOV then
            local priority = distFromCrosshair
            if not _G.NearestCrosshair then
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    priority = (root.Position - t.part.Position).Magnitude
                else
                    priority = distFromCrosshair
                end
            end
            if priority < bestDist then
                bestDist = priority
                best = t.instance
                bestTargetObj = t
            end
        end
    end

    if best and bestTargetObj then
        if _G.StrongLock then
            strongLockTarget = bestTargetObj
        end
        return best, bestTargetObj.part
    end
    return nil
end

local function updateAim()
    if not _G.Aimbot_Enabled then return end
    local target, targetPart = getTarget()
    if targetPart then
        local cam = Workspace.CurrentCamera
        local targetPos = targetPart.Position
        if aimPredict > 0 then
            local hum = target:FindFirstChildOfClass("Humanoid") or (target.Character and target.Character:FindFirstChildOfClass("Humanoid"))
            if hum then
                targetPos = targetPos + (hum.MoveDirection * aimPredict)
            end
        end
        local dir = (targetPos - cam.CFrame.Position).Unit
        local current = cam.CFrame.LookVector
        local angle = math.acos(current:Dot(dir))
        if angle > 0.01 then
            local step = math.min(1 / aimSmooth, 1)
            local newDir = current:Lerp(dir, step)
            cam.CFrame = CFrame.new(cam.CFrame.Position, cam.CFrame.Position + newDir)
        end
    end
end

local aimConnection
local function startAim()
    if aimConnection then aimConnection:Disconnect() end
    if _G.Aimbot_Enabled then
        aimConnection = RunService.RenderStepped:Connect(updateAim)
    end
end

local function toggleAim(state)
    _G.Aimbot_Enabled = state
    fovCircle.Visible = _G.FOV_Visible and state
    if not state then
        strongLockTarget = nil
    end
    startAim()
end

local function toggleFOV(state)
    _G.FOV_Visible = state
    fovCircle.Visible = state and _G.Aimbot_Enabled
end

